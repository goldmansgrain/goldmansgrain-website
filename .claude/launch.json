{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python Static Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    },
    {
      "name": "Live Server (auto-reload)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=3001", "--no-browser"],
      "port": 3001
    }
  ]
}
